# Flask Config
FLASK_ENV=production
SECRET_KEY=generate-a-safe-secret-key
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
ADMIN_PASSWORD=change-this-password

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_admin_group_chat_id

# Groq AI
GROQ_API_KEY=your_groq_api_key

# Communications (Vynfy SMS)
SMS_PROVIDER=vynfy
VYNFY_API_KEY=your_vynfy_api_key
VYNFY_SENDER_ID=SlideinGH
VYNFY_API_URL=https://venfy.sasulabs.me
SITE_URL=https://your-domain.com
VYNFY_WEBHOOK_SECRET=

# Folder Config
UPLOAD_FOLDER=app/static/uploads
MAX_CONTENT_LENGTH=16777216