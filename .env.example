FLASK_ENV=development
SECRET_KEY=change-me-to-something-secure
DATABASE_URL=postgresql://user:password@localhost:5432/slidin_store
ADMIN_PASSWORD=admin123
UPLOAD_FOLDER=app/static/uploads
MAX_CONTENT_LENGTH=16777216

# AI Engine (Groq) — powers insights, chat, product descriptions
GROQ_API_KEY=gsk_your_groq_api_key_here

# Telegram Bot — order alerts + AI chat via Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_or_group_id

# Site URL — required for Telegram webhook auto-registration
# Set this to your deployed domain e.g. https://slidein.gh
SITE_URL=